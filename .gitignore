# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/

# Data — raw inputs are immutable and large; never commit their contents
data/raw/*
data/intermediate/*
data/final/*
data/quality_reports/*
# Keep directory structure via .gitkeep
!data/raw/.gitkeep
!data/intermediate/.gitkeep
!data/final/.gitkeep
!data/quality_reports/.gitkeep

# Results — generated outputs; keep directory structure only
results/model_selection/*
results/simulations/*
results/injury_sims/*
!results/model_selection/.gitkeep
!results/simulations/.gitkeep
!results/injury_sims/.gitkeep
!results/model_selection/chosen_model_*.json

# Notebooks checkpoints
.ipynb_checkpoints/

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Ruff cache
.ruff_cache/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/
*.swp
